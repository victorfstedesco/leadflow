      "Bash(curl -s -o /dev/null -w \"clients: %{http_code}\\\\n\" http://127.0.0.1:8000/clientes)",
      "Bash(rm -f /tmp/cookies.txt)",
      "Bash(curl -s -c /tmp/cookies.txt http://127.0.0.1:8000/login)"
    ]
  }
